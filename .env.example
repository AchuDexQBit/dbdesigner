# Copy to .env.local and fill in for local dev. Do not commit .env.local.
#
# Full API URL. When its host ≠ the SPA host, the app uses only the path (e.g.
# /app) on the SPA origin so the browser does not cross-origin (no CORS).
# Nginx must proxy /app → this URL. npm run dev: Vite proxies /app automatically.
VITE_API_BASE_URL=https://dbdesigner-api.dexqbit.local/app
#
# Only if the API has working CORS and you want the browser to call it directly:
# VITE_API_CROSS_ORIGIN=true
#
# Leave empty on GETs to skip CORS preflight (see src/utils/apiBase.ts).
VITE_DEXI_VERSION=
